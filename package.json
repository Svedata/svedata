{
  "name": "svedata",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source TypeScript SDK för svenska myndighets-API:er",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:pack": "bash scripts/release-pack.sh",
    "release:verify": "bash scripts/release-verify.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
